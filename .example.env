# Environment variables for JDMatch AI Project
# Copy this file to .env and update values as needed

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jd_match_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=24h

# LLM Provider (OpenAI compatible)
OPENAI_API_KEY=your-OPENAI_API_KEY
OPENAI_MODEL=your-model-name

# Embeddings
OPENAI_EMBEDDING_MODEL=your-OPENAI_EMBEDDING_MODEL

# Additional settings
NEXTAUTH_SECRET=your-nextauth-secret-key-at-least-32-characters-long
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Security - DO NOT SET TO 0 IN PRODUCTION!
NODE_TLS_REJECT_UNAUTHORIZED=1