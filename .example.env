# Environment variables for JDMatch AI Project
# Copy this file to .env and update values as needed

# ============================================
# Database
# ============================================
# 本地开发（直连本地 PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jd_match_db
# 本地无需分离直连/连接池，DIRECT_DATABASE_URL 留空
# DIRECT_DATABASE_URL=

# 生产环境（Neon 连接池）：
#   DATABASE_URL          = 连接池 URL（带 -pooler，给应用查询用）
#   DIRECT_DATABASE_URL   = 直连 URL（不带 -pooler，给 prisma migrate 用）
# 示例：
# DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# DIRECT_DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT
# ============================================
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# LLM Provider (OpenAI 兼容)
# ============================================
OPENAI_API_KEY=your-OPENAI_API_KEY
OPENAI_MODEL=deepseek-chat
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# GitHub OAuth
# ============================================
# 开发环境（本地）：
#   GITHUB_CLIENT_ID=Ov23liBHTDmOqRYOtbij
#   GITHUB_CLIENT_SECRET=73bbf9ac76bf8fa6059b23640094153dd0fa88a4
#   GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback
#
# 生产环境（Railway 后端 + Vercel 前端）：
#   前往 https://github.com/settings/developers 创建一个新的 OAuth App
#   Homepage URL 填前端域名，Callback URL 填后端域名/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://your-api-domain.up.railway.app/auth/github/callback

# ============================================
# 应用 URL
# ============================================
NEXTAUTH_SECRET=your-nextauth-secret-key-at-least-32-characters-long
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ============================================
# 安全
# ============================================
# 生产环境务必设为 1！
NODE_TLS_REJECT_UNAUTHORIZED=1

# ============================================
# 文件存储（S3 兼容）
# ============================================
# 本地开发：使用 MinIO (docker-compose up -d 启动)
#   无需配置，代码自动连接 localhost:9000 (minioadmin/minioadmin)
#
# 生产环境 (Cloudflare R2)：
#   AWS_S3_BUCKET=jd-match-uploads
#   AWS_S3_REGION=auto
#   AWS_ACCESS_KEY_ID=your-r2-access-key-id
#   AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
#   CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
#
# 生产环境 (AWS S3)：
#   AWS_S3_BUCKET=jd-match-uploads
#   AWS_S3_REGION=us-east-1
#   AWS_ACCESS_KEY_ID=your-aws-access-key-id
#   AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=